DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
CLIENT_SECRET=your_oauth_client_secret_here
GUILD_ID=your_test_server_id_here
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Max yt-dlp processes running in parallel (resolve/search/playlist).
# Caps the CPU spike when many servers /play at once; extra requests queue.
# Defaults to 3 if unset. Raise it if you give the LXC more cores.
YTDLP_MAX_CONCURRENT=3

# On-disk audio cache: replaying a track reads from disk instead of
# re-running yt-dlp. Cap the cache size (MB, default 4096); least-recently
# played tracks are evicted first. Optionally override the directory
# (default <repo>/.cache/audio).
AUDIO_CACHE_MAX_MB=4096
#AUDIO_CACHE_DIR=/var/cache/discord-music-bot
